{
  "datasets": [
    {
      "name": "66cec181",
      "displayName": "vehiculos_electricos_registrados",
      "queryLines": [
        "select * from catalog_smartdata_final.golden.golden_ev_model_popularity order by vehicles_registered desc limit 30"
      ],
      "columns": [
        {
          "displayName": "Marca - Modelo",
          "description": "Etiqueta combinada de marca y modelo del vehículo",
          "expression": "CONCAT(make, ' - ', model)"
        }
      ]
    },
    {
      "name": "dc0964b1",
      "displayName": "ratio_rango_km_precio_usd",
      "queryLines": [
        "SELECT\n",
        "  make,\n",
        "  round(avg_specs_range_km, 0) as avg_specs_range_km,\n",
        "  round(avg_price, 0) as avg_price,\n",
        "  round(range_per_price_ratio, 4) as range_per_price_ratio,\n",
        "  updated_ts,\n",
        "  ROW_NUMBER() OVER (ORDER BY range_per_price_ratio DESC) as rank_order\n",
        "FROM\n",
        "  catalog_smartdata_final.golden.golden_make_range_price_ratio\n",
        "WHERE\n",
        "  range_per_price_ratio IS NOT NULL\n",
        "ORDER BY\n",
        "  range_per_price_ratio DESC\n",
        "LIMIT 10"
      ],
      "columns": [
        {
          "displayName": "Km por $1,000 USD",
          "description": "Índice de autonomía por cada $1,000 USD invertidos",
          "expression": "range_per_price_ratio * 1000"
        },
        {
          "displayName": "Marca (Ranking)",
          "description": "Marca con ranking por índice rango/precio",
          "expression": "CONCAT(CAST(rank_order AS STRING), '. ', make)"
        }
      ]
    }
  ],
  "pages": [
